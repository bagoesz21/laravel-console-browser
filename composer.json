{
  "name": "bagoesz21/laravel-console-browser",
  "description": "Browser console for Laravel Framework.",
  "keywords": [
    "php",
    "laravel",
    "lumen",
    "browser",
    "console",
    "console browser"
  ],
  "license": "MIT",
  "require": {
    "php": ">=5.5.9",
    "illuminate/support": ">=5.1.0"
  },
  "autoload": {
    "psr-4": {
      "Bagoesz21\\ConsoleBrowser\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Bagoesz21\\ConsoleBrowser\\ConsoleBrowserServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
